# klawed Sandbox Container - Minimal Runtime Image
# Multi-stage build to keep the final image compact
#
# Build on fandalf (same x86_64 arch as production):
#   podman build -f Dockerfile.sandbox -t klawed-sandbox:latest .
#
# Transfer to production:
#   podman save klawed-sandbox:latest | ssh filesurf-0 'podman load'
#
# Run:
#   podman run -it --rm -e OPENAI_API_KEY=$OPENAI_API_KEY \
#     -v /path/to/workspace:/workspace:Z klawed-sandbox:latest
#
# Note: Container runs as root
#
# See docs/docker-sandbox-deployment.md for full deployment guide


# =============================================================================
# Stage 1: Build Stage - Full build environment
# =============================================================================
FROM debian:12-slim AS builder

LABEL stage="builder"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build essentials
    build-essential \
    gcc \
    make \
    pkg-config \
    git \
    ca-certificates \
    curl \
    wget \
    \
    # klawed C dependencies (dev packages)
    libcurl4-openssl-dev \
    libcjson-dev \
    libsqlite3-dev \
    libssl-dev \
    libbsd-dev \
    libncursesw5-dev \
    \
    # sqlite-vector build dependencies
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy source code
COPY . .

# Clone and build sqlite-vector extension for vector similarity search
# sqlite-vector provides vector search capabilities for the memory system
# Using v0.9.60 - stable release with verified API
RUN git clone --depth 1 --branch 0.9.60 https://github.com/sqliteai/sqlite-vector.git && \
    cd sqlite-vector && \
    make && \
    ls -lh dist/vector.so && \
    mkdir -p /build/vendors/sqlite-vector && \
    cp dist/vector.so /build/vendors/sqlite-vector/vector0.so

# Build klawed (no longer needs MEMVID flag - uses SQLite-based memory system)
RUN make clean && \
    make && \
    ls -lh build/klawed

# =============================================================================
# Stage 2: Runtime Stage - Minimal production image
# =============================================================================
FROM debian:12-slim

LABEL maintainer="FileSurf Team"
LABEL description="Sandbox container for running the klawed AI agent"
LABEL version="2.0"

ENV DEBIAN_FRONTEND=noninteractive

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Networking
    curl \
    wget \
    ca-certificates \
    \
    # Git for agent workspace operations
    git \
    openssh-client \
    \
    # Python for agent tasks
    python3 \
    python3-pip \
    python3-venv \
    \
    # Essential CLI tools
    jq \
    unzip \
    zip \
    rclone \
    \
    # Runtime libraries for klawed (NOT -dev packages)
    libcjson1 \
    libcurl4 \
    libsqlite3-0 \
    libssl3 \
    libbsd0 \
    libncursesw6 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Copy klawed binary from builder
COPY --from=builder /build/build/klawed /usr/local/bin/klawed

# Copy sqlite-vector extension from builder
COPY --from=builder /build/vendors/sqlite-vector/vector0.so /usr/local/lib/vector0.so

# Copy entrypoint script
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

# Set up library paths and permissions
RUN chmod +x /usr/local/bin/klawed && \
    chmod +x /usr/local/bin/docker-entrypoint.sh && \
    ldconfig

# Create workspace directory structure
RUN mkdir -p /workspace/.klawed/logs /workspace/.klawed/mcp

# Set up default working directory
WORKDIR /workspace

# Set environment variables for runtime
ENV LD_LIBRARY_PATH=/usr/local/lib \
    HOME=/root \
    TERM=xterm-256color

# Configure git
RUN git config --system init.defaultBranch main \
    && git config --system user.email "agent@sandbox.local" \
    && git config --system user.name "Klawed Agent"

# Run as root

# Default entrypoint - accepts all arguments
# The entrypoint script ensures directories exist in the mounted volume
# Usage examples:
#   docker run image-name --sqlite-queue /path/to/queue.db
#   docker run image-name -u /path/to/socket
#   docker run image-name "your prompt here"
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
