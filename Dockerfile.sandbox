# klawed Sandbox Container with Web Browse Agent - Minimal Runtime Image
# Multi-stage build to keep the final image compact
#
# Build on fandalf (same x86_64 arch as production):
#   podman build -f Dockerfile.sandbox -t klawed-sandbox:latest .
#
# Transfer to production:
#   podman save klawed-sandbox:latest | ssh filesurf-0 'podman load'
#
# Run:
#   podman run -it --rm -e OPENAI_API_KEY=$OPENAI_API_KEY \
#     -v /path/to/workspace:/workspace:Z klawed-sandbox:latest
#
# Note: Container runs as root
#
# See docs/docker-sandbox-deployment.md for full deployment guide


# =============================================================================
# Stage 1: Build Stage - Full build environment
# =============================================================================
FROM debian:12-slim AS builder

LABEL stage="builder"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install build dependencies including Go
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build essentials
    build-essential \
    gcc \
    make \
    pkg-config \
    git \
    ca-certificates \
    curl \
    wget \
    \
    # klawed C dependencies (dev packages)
    libcurl4-openssl-dev \
    libcjson-dev \
    libsqlite3-dev \
    libssl-dev \
    libbsd-dev \
    libncursesw5-dev \
    \
    # sqlite-vector build dependencies
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install Go 1.22+ for web_browse_agent
ENV GO_VERSION=1.22.0
RUN wget -q https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz && \
    rm go${GO_VERSION}.linux-amd64.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/go"
ENV PATH="${GOPATH}/bin:${PATH}"

WORKDIR /build

# Copy source code
COPY . .

# Clone and build sqlite-vector extension for vector similarity search
# sqlite-vector provides vector search capabilities for the memory system
RUN git clone --depth 1 --branch v0.0.5 https://github.com/sqliteai/sqlite-vector.git && \
    cd sqlite-vector && \
    make && \
    ls -lh vector0.so && \
    # Copy to a known location for later
    cp vector0.so /build/vendors/sqlite-vector/vector0.so

# Build klawed (no longer needs MEMVID flag - uses SQLite-based memory system)
RUN make clean && \
    make && \
    ls -lh build/klawed

# Build web_browse_agent
RUN cd tools/web_browse_agent && \
    go mod download && \
    go build -ldflags "-s -w" -o web_browse_agent ./cmd/web_browse_agent && \
    ls -lh web_browse_agent && \
    chmod +x web_browse_agent

# =============================================================================
# Stage 2: Runtime Stage - Minimal production image with Chromium
# =============================================================================
FROM debian:12-slim

LABEL maintainer="FileSurf Team"
LABEL description="Sandbox container for running the klawed AI agent with web browser capabilities"
LABEL version="2.0"

ENV DEBIAN_FRONTEND=noninteractive

# Install runtime dependencies including Chromium and Playwright deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Networking
    curl \
    wget \
    ca-certificates \
    \
    # Git for agent workspace operations
    git \
    openssh-client \
    \
    # Python for agent tasks
    python3 \
    python3-pip \
    python3-venv \
    \
    # Essential CLI tools
    jq \
    unzip \
    zip \
    rclone \
    \
    # Runtime libraries for klawed (NOT -dev packages)
    libcjson1 \
    libcurl4 \
    libsqlite3-0 \
    libssl3 \
    libbsd0 \
    libncursesw6 \
    \
    # Chromium and browser dependencies for Playwright
    chromium \
    chromium-driver \
    # Additional Playwright dependencies
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libdbus-1-3 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    libxshmfence1 \
    # Fonts for proper rendering
    fonts-liberation \
    fonts-noto-color-emoji \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Copy klawed binary from builder
COPY --from=builder /build/build/klawed /usr/local/bin/klawed

# Copy sqlite-vector extension from builder
COPY --from=builder /build/vendors/sqlite-vector/vector0.so /usr/local/lib/vector0.so

# Copy web_browse_agent binary from builder
COPY --from=builder /build/tools/web_browse_agent/web_browse_agent /usr/local/bin/web_browse_agent

# Copy entrypoint script
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

# Set up library paths and permissions
RUN chmod +x /usr/local/bin/klawed && \
    chmod +x /usr/local/bin/web_browse_agent && \
    chmod +x /usr/local/bin/docker-entrypoint.sh && \
    ldconfig

# Install Go runtime (needed by Playwright for web_browse_agent)
ENV GO_VERSION=1.22.0
RUN wget -q https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz && \
    rm go${GO_VERSION}.linux-amd64.tar.gz
ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOPATH="/root/go"
ENV PATH="${GOPATH}/bin:${PATH}"

# Install Playwright CLI and download Chromium browser
# This pre-installs the browsers so web_browse_agent doesn't need to download them at runtime
RUN go install github.com/playwright-community/playwright-go/cmd/playwright@latest && \
    playwright install chromium && \
    # Verify Chromium was installed
    ls -lah ~/.cache/ms-playwright/ || true

# Create workspace directory structure
RUN mkdir -p /workspace/.klawed/logs /workspace/.klawed/mcp /var/log/web-agent

# Create web_browse_agent session directory
RUN mkdir -p /root/.web-agent/sessions

# Set up default working directory
WORKDIR /workspace

# Set environment variables for runtime
ENV LD_LIBRARY_PATH=/usr/local/lib \
    HOME=/root \
    TERM=xterm-256color \
    # Browser configuration for web_browse_agent
    BROWSER_TYPE=CHROMIUM \
    BROWSER_HEADLESS=true \
    KLAWED_WEB_BROWSE_AGENT_PATH=/usr/local/bin/web_browse_agent \
    # Point to system Chromium for Playwright
    CHROMIUM_EXECUTABLE=/usr/bin/chromium \
    # Enable web_browse_agent logging for debugging
    WEB_AGENT_LOG_FILE=/var/log/web-agent/web-agent.log \
    # Playwright browsers are pre-installed in the image
    PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Configure git
RUN git config --system init.defaultBranch main \
    && git config --system user.email "agent@sandbox.local" \
    && git config --system user.name "Klawed Agent"

# Run as root

# Default entrypoint - accepts all arguments
# The entrypoint script ensures directories exist in the mounted volume
# Usage examples:
#   docker run image-name --sqlite-queue /path/to/queue.db
#   docker run image-name -u /path/to/socket
#   docker run image-name "your prompt here"
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
