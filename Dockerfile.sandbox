# klawed Sandbox Container - Minimal Runtime Image
# Multi-stage build to keep the final image compact (~250MB)
#
# Build on fandalf (same x86_64 arch as production):
#   docker build -f Dockerfile.sandbox -t klawed-sandbox:latest .
#
# Transfer to production:
#   docker save klawed-sandbox:latest | ssh filesurf-0 'docker load'
#
# Run:
#   docker run -it --rm -e OPENAI_API_KEY=$OPENAI_API_KEY \
#     -v /path/to/workspace:/workspace:Z klawed-sandbox:latest
#
# Note: Container handles workspace permissions automatically via gosu
# Do NOT use --user flag; the container starts as root and drops to agent user
# Security: Use --cap-drop=ALL but NOT --security-opt=no-new-privileges (needed for gosu)
#
# See docs/docker-sandbox-deployment.md for full deployment guide


# =============================================================================
# Stage 1: Build Stage - Full build environment
# =============================================================================
FROM debian:12-slim AS builder

LABEL stage="builder"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build essentials
    build-essential \
    gcc \
    make \
    pkg-config \
    git \
    ca-certificates \
    curl \
    \
    # klawed C dependencies (dev packages)
    libcurl4-openssl-dev \
    libcjson-dev \
    libsqlite3-dev \
    libssl-dev \
    libbsd-dev \
    libncursesw5-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Rust (needed for memvid-ffi)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /build

# Copy source code
COPY . .

# Build memvid-ffi Rust library
RUN cd vendor/memvid-ffi && \
    cargo build --release && \
    ls -lh target/release/libmemvid_ffi.a && \
    ls -lh target/release/libmemvid_ffi.so

# Build klawed with memvid enabled, ZMQ disabled (keeps it simple)
RUN make clean && \
    make MEMVID=1 ZMQ=0 && \
    ls -lh build/klawed && \
    # Verify memvid is linked
    ldd build/klawed | grep -q memvid || echo "WARNING: memvid not dynamically linked (may be static)"

# =============================================================================
# Stage 2: Runtime Stage - Minimal production image
# =============================================================================
FROM debian:12-slim

LABEL maintainer="FileSurf Team"
LABEL description="Sandbox container for running the klawed AI agent"
LABEL version="1.0"

ENV DEBIAN_FRONTEND=noninteractive

# Install only runtime dependencies (not dev packages)
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Networking
    curl \
    wget \
    ca-certificates \
    \
    # Git for agent workspace operations
    git \
    openssh-client \
    \
    # Python for agent tasks
    python3 \
    python3-pip \
    python3-venv \
    \
    # Essential CLI tools
    jq \
    unzip \
    zip \
    \
    # gosu for dropping privileges in entrypoint
    gosu \
    \
    # Runtime libraries for klawed (NOT -dev packages)
    libcjson1 \
    libcurl4 \
    libsqlite3-0 \
    libssl3 \
    libbsd0 \
    libncursesw6 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user for running the agent
# Use explicit UID/GID 1000 to match typical host user for volume permissions
RUN groupadd -g 1000 agent && \
    useradd -m -u 1000 -g 1000 -s /bin/bash agent

# Copy klawed binary from builder
COPY --from=builder /build/build/klawed /usr/local/bin/klawed

# Copy memvid shared library from builder
COPY --from=builder /build/vendor/memvid-ffi/target/release/libmemvid_ffi.so /usr/local/lib/libmemvid_ffi.so

# Copy entrypoint script
COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh

# Set up library paths and permissions
RUN chmod +x /usr/local/bin/klawed && \
    chmod +x /usr/local/bin/docker-entrypoint.sh && \
    ldconfig

# Create workspace directory structure
# Note: This gets overlaid by volume mount, entrypoint fixes permissions
RUN mkdir -p /workspace/.klawed/logs /workspace/.klawed/mcp && \
    chown -R agent:agent /workspace

# Set up default working directory
WORKDIR /workspace

# Set environment variables for runtime
ENV LD_LIBRARY_PATH=/usr/local/lib \
    HOME=/workspace \
    TERM=xterm-256color

# Configure git for the agent user (as root, will be used after gosu)
RUN git config --system init.defaultBranch main \
    && git config --system user.email "agent@sandbox.local" \
    && git config --system user.name "Klawed Agent"

# Stay as root - entrypoint will drop to agent user via gosu
# This allows fixing volume permissions before running as non-root

# Default entrypoint - accepts all arguments
# The entrypoint script ensures directories exist in the mounted volume
# Usage examples:
#   docker run image-name --sqlite-queue /path/to/queue.db
#   docker run image-name -u /path/to/socket
#   docker run image-name "your prompt here"
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
