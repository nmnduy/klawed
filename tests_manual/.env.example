# Example environment variables for provider config testing
# Copy this file to .env and fill in your actual API keys
# DO NOT commit the .env file with real keys!

# For sonnet-4.5 (Local LM Studio) - optional, may not need auth
# SONNET_4_5_API_KEY=your-lm-studio-key

# For minimax-2.1 (MiniMax API)
MINIMAX_API_KEY=your-minimax-api-key

# For kimi-k2.5 (Moonshot AI)
MOONSHOT_AI_API_KEY=your-moonshot-api-key

# For AWS Bedrock
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-west-2
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
